# Copy this file to .env locally. In Netlify, set the same values in Site settings > Environment variables.
PUBLIC_SITE_URL=https://lantso.com
PORT=3000

# Stripe Checkout, no Shopify.
STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=

# Leave empty to let Stripe choose eligible dashboard-enabled methods.
# Optional example: card,klarna,paypal
STRIPE_PAYMENT_METHOD_TYPES=

# Set true only after Stripe Tax is configured for the business.
STRIPE_AUTOMATIC_TAX=false

# Production storage uses Netlify Blobs through @netlify/blobs.
# Local development falls back to data/inventory-state.json unless this is set differently.
LANTSO_STORAGE_DRIVER=
LANTSO_CHECKOUT_TTL_MS=2700000
LANTSO_WEBHOOK_GRACE_MS=7200000

# Launch gate. Keep false for public SEO/indexing. Set true only for a private pre-launch gate.
LANTSO_GATE_ENABLED=false
# Required only when LANTSO_GATE_ENABLED=true; no production fallback is used.
# Generate with:
# node -e "console.log(require('crypto').createHash('sha256').update('your-password').digest('hex'))"
LANTSO_ACCESS_HASH=

# Contact + paid order email notifications.
# Resend has a free tier; set these two values to send direct emails from /api/contact and /api/webhook.
STORE_EMAIL=contact@lantso.com
CONTACT_TO_EMAIL=contact@lantso.com
CONTACT_FROM_EMAIL=
RESEND_API_KEY=
CONTACT_EMAIL_REQUIRED=false
